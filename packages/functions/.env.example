# SMTP Configuration
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=your-smtp-password

# Sentry Error Tracking
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_ENABLED=false

# Email Settings
EMAIL_ENABLED=true
EMAIL_TEST_RECIPIENT=

# Application
APP_DOMAIN=https://groceries-list.com

# Comma-separated admin user UIDs allowed to run privileged callables (e.g. migrateProfiles)
ADMIN_UIDS=
